<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net8.0</TargetFramework>
    <Nullable>enable</Nullable>
    <LangVersion>latest</LangVersion>
    <RootNamespace>Photonic.Sample.Raylib</RootNamespace>
    <AssemblyName>Photonic.Sample.Raylib</AssemblyName>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Raylib-cs" Version="6.1.1" />
    <PackageReference Include="StbImageSharp" Version="2.30.15" />
    <PackageReference Include="Prowl.Vector" Version="2.1.0" />
    <PackageReference Include="Prowl.Clay" Version="0.5.0" />
    <PackageReference Include="Prowl.Unwrapper" Version="0.1.0" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\Photonic\Photonic.csproj" />
  </ItemGroup>

  <ItemGroup>
    <Compile Include="..\Photonic.Demo\CombinedSponza.cs">
      <Link>CombinedSponza.cs</Link>
    </Compile>
    <Compile Include="..\Photonic.Demo\TrianglePacker.cs">
      <Link>TrianglePacker.cs</Link>
    </Compile>
  </ItemGroup>

  <ItemGroup>
    <Content Include="..\Assets\Sponza\glTF\**\*.*">
      <Link>Assets\Sponza\glTF\%(RecursiveDir)%(Filename)%(Extension)</Link>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
  </ItemGroup>

</Project>
